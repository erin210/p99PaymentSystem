    //json to Excel op /////////////////
    function doit(type, fn) {
        if (!DataReport || DataReport.length === 0) {
            alert("目前沒有資料可供下載");
            return;
        }

        //根據 HTML 欄位順序進行 map
        const excelRows = DataReport.map(item => {
            // 處理日期：直接從原始資料切掉毫秒，確保空格被保留
            const rawDate = item.TransTime || "";
            const cleanDate = rawDate.includes('.') ? rawDate.split(
                '.')[0] : rawDate;

            return {
                "客戶名稱": item.CustomerName,
                "PAID": item.PAID_NAME,
                "交易狀態": item.PAY_STATUS,
                "商品編號": item.PRODUCT_ID,
                "商品名稱": item.PRODUCT_NAME,
                "ACC": item.USER_ACCTID ? item.USER_ACCTID : '-',
                "CID": "C001560000156", 
                "COID": String(item.C_COID), // 強制轉字串
                "交易日期": cleanDate, // ex "2026-03-01 00:20:22"
                "CUID": item.CUID,
                "金額": item.AMOUNT
            };
        });

        //轉換為工作表
        var ws = XLSX.utils.json_to_sheet(excelRows);

        //處理格式與底色
        const range = XLSX.utils.decode_range(ws['!ref']);
        for (let C = range.s.c; C <= range.e.c; ++C) {
            // --- 設定標題列 (R=0) 樣式 ---
            const headerAddress = XLSX.utils.encode_cell({
                r: 0,
                c: C
            });
            if (ws[headerAddress]) {
                ws[headerAddress].s = {
                    fill: {
                        patternType: 'solid',
                        fgColor: {
                            rgb: '5581C0'
                        }
                    },
                    font: {
                        bold: true,
                        color: {
                            rgb: 'ffffff'
                        }
                    },
                    alignment: {
                        horizontal: 'center',
                        vertical: 'center'
                    }
                };
            }

            // --- 設定內容列 (R>0) 格式 ---
            for (let R = 1; R <= range.e.r; ++R) {
                const cellAddress = XLSX.utils.encode_cell({
                    r: R,
                    c: C
                });
                if (ws[cellAddress]) {
                    // 強制所有欄位為「文字」類型 (t: 's')
                    ws[cellAddress].t = 's';
                    ws[cellAddress].z = '@';
                }
                if (C === 10) { // 第 11 欄，索引為 10
                    ws[cellAddress].s = {
                        alignment: {
                            horizontal: 'right', // 靠右對齊
                            vertical: 'center'
                        }
                    };
                } else {
                    // 其他欄位預設靠左或置中（可自選）
                    ws[cellAddress].s = {
                        alignment: {
                            horizontal: 'left',
                            vertical: 'center'
                        }
                    };
                }
            }
        }

        // 4. 設定欄位寬度 (根據內容長度稍微調整)
        ws['!cols'] = [{
                wch: 20
            }, // 客戶名稱
            {
                wch: 15
            }, // PAID
            {
                wch: 12
            }, // 交易狀態
            {
                wch: 15
            }, // 商品編號
            {
                wch: 20
            }, // 商品名稱
            {
                wch: 15
            }, // ACC
            {
                wch: 20
            }, // CID
            {
                wch: 25
            }, // COID (最長的欄位)
            {
                wch: 20
            }, // 交易日期
            {
                wch: 15
            }, // CUID
            {
                wch: 12
            } // 金額
        ];

        // 5. 建立活頁簿並下載
        var wb = XLSX.utils.book_new();
        XLSX.utils.book_append_sheet(wb, ws, "交易明細表");
        XLSX.writeFile(wb, fn || '交易明細表.' + (type || 'xlsx'));
    }
    //json to Excel ed /////////////////
 
