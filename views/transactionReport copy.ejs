        //查詢前/////////////////
        function renderInfo(json) {
            
            $('.results_area').hide(); //查詢結果區塊先隱藏
            $('#userID').text(json.U_ACCOUNT);
            $('#MID_NUM').text(`MID：${json.MID}`);
            $('#U_COID').val(json.U_COID);

            

            //印 hidden input----------------------------
            const defalutInputs={
                "U_CID":"",
                "U_YMD_S":"",
                "U_YMD_E":"",
                "U_STATUS":""
            }
            Object.entries(defalutInputs).forEach(([k, value]) => {
                // 過濾掉內層物件
                if (typeof value === 'object' && value !== null) return;
                const eleName = `#${k}`;
                if ($(eleName).length <= 0) {
                    appendElement_Input('#form', k, value);
                } else {
                    $(eleName).val(value);
                }
            });
            

            //CID:讀取＋列印----------------------------            
            const cidArray = JSON.parse(json.CID);
            const ucidString=cidArray.join(',');

            // console.log('Cid:'+cidArray);
            
            $('#cid-multiple').html('');
            cidArray.forEach(cid => {
                const option = `<option value="${cid}" selected>${cid}</option>`;
                $('#cid-multiple').append(option);
                
            });

            //U_CID讀取+input Val
            $('input[name=U_CID]').val(ucidString);
            // console.log(ucidString);

            //STATUS:讀取＋列印----------------------------
            const statusMap = {
                "S": "成功單",
                "R": "調退單",
                "F": "失敗單"
            };

            //印出option
            Object.entries(statusMap).forEach(([key, text]) => {
                const option = `<option value="${key}">${text}</option>`;
                $('#status-multiple').append(option);
            });

            
            //判斷U_COID    
            // if(json.U_COID || json.U_COID!==""){
                
            //     $('#U_COID').val(json.U_COID);
            //     // localStorage.setItem('selectedSearchDateId', 'date01');
            //     console.log("有U_COID");
            // }

            //判斷有無U_STATUS
            if (json.U_STATUS && json.U_STATUS.trim() !== "") {
                localStorage.setItem('selectedSearchTypeId', 'type02');
                console.log("進階搜尋");
                $('#status-multiple').html('');
                // 變成陣列：["S", "R"]
                const jsonU_STATUS = json.U_STATUS.split(',');

                // Object.keys(statusMap) 會拿到 ["S", "R", "F"]
                const statusObj = Object.keys(statusMap).reduce((acc, key) => {
                    const text = statusMap[key]; // 拿到 "成功單"、"調退單"、"失敗單"
                    acc[key] = text;            

                    //檢查判斷
                    if (jsonU_STATUS.includes(key)) {
                        // json有
                        const option = `<option value="${key}" selected>${text}</option>`;
                        $('#status-multiple').append(option);
                    } else {
                        // json沒有
                        const option = `<option value="${key}">${text}</option>`;
                        $('#status-multiple').append(option);
                    }

                    return acc;
                }, {});
            }else{
                localStorage.setItem('selectedSearchTypeId', 'type01');
                console.log("快速搜尋");
            }

            // $('#status-multiple').trigger('change');
        }

        //查詢後/////////////////
        let DataReport = [];
        function renderInfo_2(json){
            //印 hidden input
            Object.entries(json).forEach(([k, value]) => {
                // 過濾掉內層object
                if (typeof value === 'object' && value !== null) return;

                const eleName = `#${k}`;
                if ($(eleName).length <= 0) {
                    appendElement_Input('#form', k, value);
                } else {
                    
                    $(eleName).val(value);
                }
            });

            
            DataReport = json.Transaction_Report;
            
            const dataNN = json.Transaction_Report.length;
            $('#dataNN').text(dataNN)//顯示共Ｎ筆

            const historyDATA = json.Transaction_Report // 這裡所有的資料
            initPagination(10);
            
            //顯示筆數option
            const pageSizeNumber=[10,20,50,80,100];
            const pageSelect = $('#pageSIZE');

            pageSelect.innerHTML = '';

            pageSizeNumber.forEach((size, index) => {
            // 第一個選項(10)絕對顯示，其他照計算的顯示
            if (index === 0 || pageSizeNumber[index - 1] < dataNN) {
                const option = `<option value="${size}">${size}</option>`;
                pageSelect.append(option);
            }
            });
            

            //改變顯示筆數
            $('#pageSIZE').on('change', function() {
                const newSize = $(this).val(); // 選的數值
                $('#pagination-container').pagination('destroy');

                // 重新初始化
                initPagination(parseInt(newSize));
            });


            //日期＋時間 格式
            function formatTime(tt) {
                if (!tt) return ''
                const [datePart, timePart] = tt.split(' ')
                const timePartFormate = timePart ? timePart.split('.')[0] : ''

                // 在兩個 b 標籤中間加一個真正的空格
                return `<b>${datePart}</b> <b>${timePartFormate}</b>`
            }

            //千元標註
            function formatCurrency(number) {
                // 確保 number 是一個整數
                if (!Number.isInteger(number)) return null

                // 將整數轉成字串，並利用正規表達式添加逗號
                return number.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ',')
            }

            //根據顯示筆數渲染畫面
            function initPagination(size) {
                $('#pagination-container').pagination({
                    dataSource: historyDATA, // 原始完整資料陣列
                    pageSize: size, // 每頁顯示幾筆
                    pageRange: 1, // 前後各 2 個，總共約 5 個
                    showFirstOnEllipsisShow: false, // 不強制顯示第一頁
                    showLastOnEllipsisShow: false, // 不強制顯示最後一頁
                    className: 'paginationjs-theme-blue', // 套用藍色主題 (可選)

                    // 切換頁碼
                    callback: function(data, pagination) {
                        // PC --------------------------------               

                        //清空表格
                        $('#historyTable').empty();
                        //清空list
                        $('#listArea ul').empty();

                        //表頭
                        const tableTH = `<tr class="list_th">
                                    <th class="acc_C_COID">COID</th>
                                    <th class="acc_CustomerName">客戶名稱</th>
                                    <th class="acc_PAID_NAME">PAID</th>
                                    <th class="acc_PRODUCT_ID">商品編號</th>
                                    <th class="acc_PRODUCT_NAME">商品名稱</th>
                                    <th class="acc_USER_ACCTID">USER ID</th>
                                    ${/* <th class="acc_C_COID">COID(Mock)</th> */ ''}
                                    <th class="acc_start_date">起單時間(Mock)</th>
                                    <th class="acc_date">交易時間</th>
                                    <th class="acc_Reason">原因</th>
                                    <th class="acc_CUID">幣別</th>
                                    <th class="acc_AMOUNT">金額</th>
                                    <th class="acc_PAY_STATUS">交易狀態</th>
                                    <th class="acc_TOOLS">操作</th>
                                </tr>
                                <tr style="height: 10px;"></tr>`;
                        $('#historyTable').append(tableTH);

                        //渲染
                        data.forEach(item => {
                            // PC --------------------------------  

                            const tableHTML = `<tr>
                                        <td class="acc_C_COID" t="s">${String(item.C_COID)}</td>
                                        <td class="acc_CustomerName">${item.CustomerName}</td>
                                        <td class="acc_PAID_NAME">${item.PAID_NAME}</td>
                                        <td class="acc_PRODUCT_ID">${item.PRODUCT_ID}</td>
                                        <td class="acc_PRODUCT_NAME">${item.PRODUCT_NAME}</td>
                                        <td class="acc_USER_ACCTID">${item.USER_ACCTID ? item.USER_ACCTID : '-'}</td>
                                        ${/* <td class="acc_C_COID" t="s"> C001560000156(Mock)</td> */ ''}
                                        <td class="acc_start_date">yyyy-mm-dd 00:00:00</td>
                                        <td class="acc_date">${item.TransTime ? formatTime(item.TransTime):'-'}</td>
                                        <td class="acc_Reason">${item.Reason ? item.Reason:'-'}</td>
                                        <td class="acc_CUID">${item.CUID}</td>
                                        <td class="acc_AMOUNT">${item.AMOUNT}</td>
                                        <td class="acc_PAY_STATUS">${item.PAY_STATUS}</td>
                                        <td class="acc_TOOLS">
                                            <button>詳細</button>
                                            <button>重試</button>
                                            </td>
                                    </tr>`;
                            $('#historyTable').append(tableHTML);

                            // M --------------------------------  
                            
                            const listINFO_HTML = `
                                    <li>
                                    <div class="list_head">
                                        <div>
                                        <span class="list_text_left acc_C_COID">COID：${ item.C_COID }</span>
                                        <span class="list_text_right">
                                            <i class="imgbox">
                                            <img src="<%- cdn %>/assets/img/icon_dropdown.svg" alt="" />
                                            </i>
                                        </span>
                                        </div>
                                        <div>
                                        <span class="list_text_left acc_AMOUNT">${ item.CUID }<b>${item.AMOUNT}</b></span>
                                       
                                        </div>
                                    </div>
                                    <div class="list_content">
                                        <div>
                                            <span class="list_text_left">商品編號</span>
                                            <span class="list_text_right">${ item.PRODUCT_ID }</span>
                                        </div>
                                        <div>
                                            <span class="list_text_left">客戶名稱</span>
                                            <span class="list_text_right">${ item.CustomerName }</span>
                                        </div>
                                        <div>
                                            <span class="list_text_left">產品名稱</span>
                                            <span class="list_text_right">${ item.PRODUCT_NAME }</span>
                                        </div>
                                        <div>
                                            <span class="list_text_left">USER ID</span>
                                            <span class="list_text_right">${ item.USER_ACCTID ? item.USER_ACCTID : '-' }</span>
                                        </div>
                                        <div>
                                            <span class="list_text_left">PAID</span>
                                            <span class="list_text_right">${ item.PAID_NAME }</span>
                                        </div>
                                        <div>
                                            <span class="list_text_left">交易狀態</span>
                                            <span class="list_text_right">${ item.PAY_STATUS }</span>
                                        </div>
                                        <div>
                                            <span class="list_text_left">起單時間</span>
                                            <span class="list_text_right">${item.CreateTime ? formatTime(item.CreateTime):'-'}</span>
                                        </div>
                                        <div>
                                            <span class="list_text_left">交易時間</span>
                                            <span class="list_text_right">${item.TransTime ? formatTime(item.TransTime):'-'}</span>
                                        </div>
                                        <div>
                                            <span class="list_text_left">原因</span>
                                            <span class="list_text_right">${item.Reason ? item.Reason:'-'}</span>
                                        </div>
                                        
                                   </div>
                                    </li>
                                    `;

                                $('#listArea ul').append(listINFO_HTML);

                        });

                        //清空list
                        // $('#listArea').empty();
                        if (Object.keys(dataNN) === 0) {
                            $('.dataEmpty').show()
                            $('.pagination').hide()
                        } else {
                            $('.dataEmpty').hide()
                            $('.pagination').show()
                        }

                        //看詳細動畫
                        $('.list_head').on('click', function() {
                            $(this).find('.imgbox')
                                .toggleClass('rotate')
                            $(this).siblings(
                                    '.list_content')
                                .toggleClass('show')
                        })
                    }
                });
            }
            
            
        }

        //批次印出 hidden input
        function appendElement_Input(ele, name, value) {
            var inputHtml = `<input type="hidden" id='${name}' name="${name}" value='${value}' />`;
            $(ele).append(inputHtml);
            // searchItemOpen();
        }
    //===============================================
    //印出DATA ed 
    //===============================================
    
    //===============================================
    //查詢區塊op
    //===============================================
        //查詢日期區間-daterangepicker
        $(function() {
            $('#date-range').daterangepicker({
                "locale": {
                    "format": "YYYY-MM-DD",
                    "separator": " ~ ",
                    "applyLabel": "確定",
                    "cancelLabel": "清除",
                    "fromLabel": "開始日期",
                    "toLabel": "結束日期",
                    "customRangeLabel": "自定義區間",
                    "daysOfWeek": ["日", "一", "二", "三", "四", "五",
                        "六"
                    ],
                    "monthNames": ["一月", "二月", "三月", "四月", "五月",
                        "六月", "七月", "八月", "九月", "十月", "十一月",
                        "十二月"
                    ],
                    "firstDay": 0
                },
                "dateLimit": {
                    "months": 1 // 限制區間一個月
                },
                "startDate": moment().startOf('month'), // 預設開始：當月 1 號 (例如：2026-06-01)
                "endDate": moment().endOf('month'),   // 預設結束：當月最後一天 (例如：2026-06-30)
                "maxDate": moment(),   // 限制最大可選日期：也是當月最後一天
                "opens": "right" // 選單往右邊彈出
            }, function(start, end, label) {
                // 將開始時間歸零到 00:00:00 並轉成 Unix 時間戳記
                const startTimestamp = start.clone().startOf(
                    'day').unix();

                // 結束時間推到 23:59:59並轉成 Unix 時間戳記
                const endTimestamp = end.clone().endOf('day')
                    .unix();

                // 塞入隱藏欄位
                $('input[name=U_YMD_S]').val(startTimestamp);
                $('input[name=U_YMD_E]').val(endTimestamp);
            });

            // --- 手機版打開時的背景---
            $('#date-range').on('show.daterangepicker', function(ev, picker) {
                if ($(window).width() < 768) {
                    $('body').addClass('modal-open-picker');
                }
            });

            $('#date-range').on('hide.daterangepicker', function(ev, picker) {
                $('body').removeClass('modal-open-picker');
            });

            //「清除」按鈕
