                const baseDate = moment(val, "YYYYMM");
                if (!baseDate.isValid()) return;

                const startTimestamp = baseDate.clone().startOf('month').unix();
                const endTimestamp = baseDate.clone().endOf('month').unix();

                $('input[name=U_YMD_S]').val(startTimestamp);
                $('input[name=U_YMD_E]').val(endTimestamp);
            }

            // 變成全域（Global）
            window.updateTimestamps = updateTimestamps; 

            // 監聽 #date-monthly
            $('#date-monthly').on('input', function() {
