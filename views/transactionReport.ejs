            // 假設 "U" 代表你的「未完成 / 中斷單」
            // 使用 Array.isArray 或轉字串確保 includes 正常運作
            if (status.includes("U")) {
                // console.log("【觸發限制】選中了未完成單，強制切換並鎖定為起單時間");

                // 1. 解鎖並勾選「起單時間」，並觸發 change 讓其他連動元件知道
                $('#status_CreateTime').prop('disabled', false).prop('checked', true).trigger('change');
                
