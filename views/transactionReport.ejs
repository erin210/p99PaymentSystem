                                        <div>
                                        <span class="list_text_left acc_COID">COID: ${ item.COID || '-' }</span>
                                        <span class="list_text_left acc_AMOUNT">${ item.CUID || '-' }<b>${item.AMOUNT || '-'}</b></span>
                                       
                                        </div>
                                    </div>
                                    <div class="list_content">
