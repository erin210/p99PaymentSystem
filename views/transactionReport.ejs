            function formatCurrency(number) {
                // 確保 number 是一個整數
                if (!Number.isInteger(number)) return null

                // 將整數轉成字串，並利用正規表達式添加逗號
                return number.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ',')
            }

