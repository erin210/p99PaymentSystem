                                        </div>
                                        <div>
                                            <span class="list_text_left"></span>
                                            <span class="list_text_right">USER ID: ${ item.USER_ACCTID || '-' }</span>
                                        </div>
                                        <div>
                                            <span class="list_text_left"></span>
                                            <span class="list_text_right">USER IP: ${ item.USER_IP || '-' }</span>
                                        </div>
                                        <div>
                                            <span class="list_text_left"></span>
                                            <span class="list_text_right">PAID: ${ item.PAID || '-' }</span>
                                        </div>
                                        <div>
                                            <span class="list_text_left"></span>
                                            <span class="list_text_right">PAID NAME: ${ item.PAID_NAME || '-' }</span>
                                        </div>
                                        <div>
                                            <span class="list_text_left"></span>
                                            <span class="list_text_right acc_PAY_STATUS">
                                                Status: ${statusString(item.PAY_STATUS, item.COID)}
                                            </span>
                                        </div>
                                        <div>
                                            <span class="list_text_left"></span>
                                            <span class="list_text_right">Create Time: ${item.CreateTime_at_Create ? formatTime(item.CreateTime_at_Create):'-'}</span>
