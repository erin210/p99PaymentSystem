            //印 hidden input----------------------------
            const defalutInputs={
                "U_CID":"",
                "U_YMD_S":"",
                "U_YMD_E":"",
                "U_STATUS":"",
                "U_STATUS_DATE":"",
                "U_ACCOUNT":json.U_ACCOUNT,
            }
            
            // $('#U_ACCOUNT').val(json.U_ACCOUNT);
            Object.entries(defalutInputs).forEach(([k, value]) => {
                // 過濾掉內層物件
                if (typeof value === 'object' && value !== null) return;
                const eleName = `#${k}`;
                if ($(eleName).length <= 0) {
                    appendElement_Input('#form', k, value);
                } else {
                    $(eleName).val(value);
                }
            });

           statusDateType(json.U_STATUS);
            

