    //json to Excel op /////////////////
    function doit(type, fn) {
        if (!DataReport || DataReport.length === 0) {
            alert("目前沒有資料可供下載");
            return;
        }
        
        // 修正：如果 MID 都一樣，直接取第一筆的 MID 當作檔名即可，不用在 map 裡面一直重複被蓋過去
        const firstMID = DataReport[0] && DataReport[0].MID ? String(DataReport[0].MID) : '';

        // 修正：加入 index 參數 (i)，解決 item.index() 報錯問題
        const excelRows = DataReport.map((item, i) => {
            return {
                "NO.": i + 1, // 修正：改成使用 map 的索引值 i
                "MID": String(item.MID) || '-',
                "CID": String(item.CID) || '-',
                "CID_NAME": String(item.CID_NAME) || '-',
                "COID": String(item.COID) || '-',
                "P99_COID": String(item.P99_COID) || '-',
                "PAID": item.PAID || '-',
                "PAID_NAME": item.PAID_NAME || '-',
                "CUID": item.CUID,
                "Amount": item.AMOUNT, // 💡 注意：這是第 10 個欄位，索引值 (C) 是 9
                "Status": statusString(item.PAY_STATUS, item.COID, true),
                "PRODUCT_ID": item.PRODUCT_ID || '-',
                "PRODUCT_NAME": item.PRODUCT_NAME || '-',
                "USER_ID": item.USER_ACCTID || '-',
                "USER_IP": item.USER_IP || '-',
                "TXTIME": item.TXTIME || '-',
                "Create Time": item.CreateTime_at_Create || '-',
                "Transaction Time": item.CreateTime_at_Transaction || '-',
                "Refund Time": item.CreateTime_at_Refund || '-',
                "REMARKS": item.REMARKS || '-'
            };
        });

        // 轉換為工作表
        var ws = XLSX.utils.json_to_sheet(excelRows);

        // 處理格式與底色
        const range = XLSX.utils.decode_range(ws['!ref']);
        for (let C = range.s.c; C <= range.e.c; ++C) {
            
            // --- 先處理內容列 (R > 0) ---
            for (let R = 1; R <= range.e.r; ++R) {
                const cellAddress = XLSX.utils.encode_cell({ r: R, c: C });
                if (ws[cellAddress]) {
                    // 強制所有欄位為「文字」類型
                    ws[cellAddress].t = 's';
                    ws[cellAddress].z = '@';
                    
                    // 修正：Amount 的 key 順序是第 10 個，所以索引 C 是 9
                    if (C === 9) { 
                        ws[cellAddress].s = {
                            alignment: {
                                horizontal: 'right', // 金額靠右
                                vertical: 'center'
                            }
                        };
                    } else {
                        ws[cellAddress].s = {
                            alignment: {
                                horizontal: 'center', // 其他靠中
                                vertical: 'center'
                            }
                        };
                    }
                }
            }

            // --- 後處理標題列 (R = 0) 樣式 ---
            // 💡 放在後面處理，才不會被上面的內容列迴圈把樣式蓋掉！
            const headerAddress = XLSX.utils.encode_cell({ r: 0, c: C });
            if (ws[headerAddress]) {
                ws[headerAddress].s = {
                    fill: {
                        patternType: 'solid',
                        fgColor: { rgb: '5581C0' }
                    },
                    font: {
                        bold: true,
                        color: { rgb: 'ffffff' }
                    },
                    alignment: {
                        horizontal: 'center',
                        vertical: 'center'
                    }
                };
            }
        }

        // 4. 設定欄位寬度
        if (ws['!ref']) {
            const range = XLSX.utils.decode_range(ws['!ref']);
            const colsWidth = [];

            for (let C = range.s.c; C <= range.e.c; ++C) {
                let maxWidth = 10; 

                for (let R = range.s.r; R <= range.e.r; ++R) {
                    const cellAddress = XLSX.utils.encode_cell({ r: R, c: C });
                    const cell = ws[cellAddress];

                    if (cell && cell.v) {
                        const cellValue = String(cell.v);
                        let len = 0;
                        for (let i = 0; i < cellValue.length; i++) {
                            if (cellValue.charCodeAt(i) > 255) {
                                len += 2; 
                            } else {
                                len += 1.1; 
                            }
                        }
                        if (len > maxWidth) {
                            maxWidth = len;
                        }
                    }
                }
                colsWidth.push({ wch: Math.ceil(maxWidth + 2) });
            }
            ws['!cols'] = colsWidth;
        }

        // 5. 建立活頁簿並下載
        var wb = XLSX.utils.book_new();
        XLSX.utils.book_append_sheet(wb, ws, firstMID || "Sheet1");
        
        const timestamp = Math.floor(Date.now() / 1000);
        const fileName = fn || `${firstMID}_${timestamp}.${type || 'xlsx'}`;

        XLSX.writeFile(wb, fileName);
    }
    //json to Excel ed /////////////////
 
    </script>
