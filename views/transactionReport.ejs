<script>
    function initFunction(jsonObj) {
        if (jsonObj && jsonObj.Transaction_Report) {
            // 偵測到json.Transaction_Report
            renderInfo(jsonObj);
            renderInfo_2(jsonObj);
            // 顯示結果區塊
            $('.results_area').show(); 
        } else {
            renderInfo(jsonObj);
            
            // 隱藏結果區塊
            $('.results_area').hide(); 
        }
    }
</script>
