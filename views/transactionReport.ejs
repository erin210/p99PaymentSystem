            //     $('#U_COID').val(json.U_COID);
            //     // localStorage.setItem('selectedSearchDateId', 'date01');
            //     console.log("有U_COID");
            // }

            //判斷有無U_STATUS
            if (Array.isArray(json.U_STATUS) && json.U_STATUS.length > 0) {
                localStorage.setItem('selectedSearchTypeId', 'type02');
                // console.log("進階搜尋");
                $('#status-multiple').html('');
                // 變成陣列：["S", "R"]
                const jsonU_STATUS = json.U_STATUS;

                // Object.keys(statusMap) 會拿到 ["S", "R", "F"]
                const statusObj = Object.keys(statusMap).reduce((acc, key) => {
                    const text = statusMap[key]; // 拿到 "成功單"、"調退單"、"失敗單"
                    acc[key] = text;            

                    //檢查判斷
                    if (jsonU_STATUS.includes(key)) {
                        // json有
                        const option = `<option value="${key}" selected>${text}</option>`;
                        $('#status-multiple').append(option);
                    } else {
                        // json沒有
                        const option = `<option value="${key}">${text}</option>`;
                        $('#status-multiple').append(option);
                    }

                    return acc;
                }, {});
            }else{
                localStorage.setItem('selectedSearchTypeId', 'type01');
                // console.log("快速搜尋");
            }

            // $('#status-multiple').trigger('change');
            // initTranslation(json)//翻譯
        }

        //查詢後/////////////////
        let DataReport = [];
