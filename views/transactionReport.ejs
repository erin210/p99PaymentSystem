                const option = `<option value="${cid}" selected>${cid}</option>`;
                $('#cid-multiple').append(option);
                
            });

            //U_CID讀取+input Val
            $('input[name=U_CID]').val(JSON.stringify(json.CID));
            $('input[name=U_STATUS]').val(JSON.stringify(json.U_STATUS));
            // console.log(u_cidString);

            

            //印出option
            Object.entries(statusMap).forEach(([key, text]) => {
                // 直接在字串內判斷：如果 key 是 "S" 就帶入 "selected"，否則留空
                const option = `<option value="${key}" ${key === "S" ? "selected" : ""}>${text}</option>`;
                $('#status-multiple').append(option);
            });

            
            //判斷U_COID    
