                // 🔵 【一般模式 (Else)】只跑 cid、status、monthly 的 UI 檢查
                if (triggerField === 'cid') CidValidator.checkUI(isInit);
                if (triggerField === 'status') StatusValidator.checkUI(isInit);
                if (triggerField === 'monthly') MonthlyValidator.checkUI(isInit);
                
                // 初始化或重置時，只檢查這三個，coid 強制隱藏
                if (isInit || triggerField === null) {
                    CidValidator.checkUI(isInit);
                    StatusValidator.checkUI(isInit);
                    MonthlyValidator.checkUI(isInit);
                    
                    // 貼心隱藏不用檢查的 coid 紅字
                    $('.coid-container').removeClass('error_input').next('.error_msg').hide(); // 這裡請替換成你實際的 coid 容器
                }
                
            } else {
                // 🟢 【Type02 模式】只跑 cid 和 coid 的 UI 檢查
                if (triggerField === 'cid') CidValidator.checkUI(isInit);
                if (triggerField === 'coid') CoidValidator.checkUI(isInit, isBlur);
                
                // 初始化或重置時，只檢查這兩個，另外兩個強制隱藏
                if (isInit || triggerField === null) {
                    CidValidator.checkUI(isInit);
                    CoidValidator.checkUI(isInit, true);
                    
                    // 貼心隱藏另外兩個不用檢查的紅字
                    $(statusPicker.passedElement.element).closest('.input_p99').removeClass('error_input').next('.error_msg').hide();
                    $('.monthly-container').removeClass('error_input').next('.error_msg').hide(); 
                }
            }

            // --- 2. 核心按鈕判斷 (依據分流結論決定按鈕狀態) ---
            let isAllValid = false;

            if (isType02) {
                // 🔵 Else：要這三個合法才行
                const isCidValid = CidValidator.isValid();
                const isStatusValid = StatusValidator.isValid();
                const isMonthlyValid = MonthlyValidator.isValid();
                isAllValid = isCidValid && isStatusValid && isMonthlyValid;
                
            } else {
                // 🟢 Type02：只要這兩個合法即可
                const isCidValid = CidValidator.isValid();
                const isCoidValid = CoidValidator.isValid();
                isAllValid = isCidValid && isCoidValid;
            }

            // --- 3. 控制按鈕狀態 ---
            const searchBtn = $('#search');
            if (isAllValid) {
                searchBtn.removeClass('disabled').removeAttr('disabled');
            } else {
                searchBtn.addClass('disabled').attr('disabled', true);
            }
        }

        

