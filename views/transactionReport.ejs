                                        <td class="acc_date">${item.CreateTime_at_Transaction ? formatTime(item.CreateTime_at_Transaction):'-'}</td>
                                        <td class="acc_date">${item.CreateTime_at_Refund ? formatTime(item.CreateTime_at_Refund):'-'}</td>
                                        <td class="acc_REMARKS">${item.REMARKS || '-'}</td>
                                        <td class="acc_PAY_STATUS">${statusString(item.PAY_STATUS, item.COID)}
                                        </td>
                                        <td class="acc_CUID">${item.CUID || '-'}</td>
                                        <td class="acc_AMOUNT">${item.AMOUNT || '-'}</td>
                                        <td class="acc_DETAIL">
                                           <button type="button" class="btn btn_blue btn-detail" data-id="${item.COID || '-'}">Detail</button>
                                            </td>
                                    </tr>`;
                            $('#historyTable').append(tableHTML);



                            // M --------------------------------  
                            
                            const listINFO_HTML = `
                                    <li>
                                    <div class="list_head">
                                        <div>
                                        <span class="list_text_left acc_CID">CID: ${ item.CID || '-' }</span>
                                        <span class="list_text_right">
                                            <i class="imgbox">
                                            <img src="<%- cdn %>/assets/img/icon_dropdown.svg" alt="" />
                                            </i>
                                        </span>
