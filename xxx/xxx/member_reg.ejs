            passwordField.attr('type', isPasswordVisible ? 'password' : 'text');

            const newIconSrc = isPasswordVisible ? pageBaseUrl + '<%- cdn %>/assets/img/icon_eye_close.svg' : pageBaseUrl + '<%- cdn %>/assets/img/icon_eye_open.svg';
            $(this).attr('src', newIconSrc);
        });

